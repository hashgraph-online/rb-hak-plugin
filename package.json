{
  "name": "@hol-org/rb-hak-plugin",
  "version": "0.1.1",
  "description": "Hedera Agent Kit plugin exposing Registry Broker operations",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "test": "jest",
    "lint": "ESLINT_USE_FLAT_CONFIG=false eslint src --ext .ts",
    "typecheck": "tsc --noEmit",
    "demo:hedera-kit": "tsx demo/hedera-agent-kit-demo.ts",
    "release": "pnpm install --frozen-lockfile && pnpm run build && pnpm publish --access public"
  },
  "keywords": [
    "hedera",
    "agent-kit",
    "plugin",
    "registry-broker"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/hashgraph-online/rb-hak-plugin"
  },
  "author": "Hashgraph Online",
  "license": "Apache-2.0",
  "dependencies": {
    "@hashgraphonline/standards-sdk": "^0.1.150",
    "@hashgraphonline/hashinal-wc": "^2.0.57",
    "@hashgraph/sdk": "^2.79.0",
    "dotenv": "^17.2.3",
    "file-type": "^20.5.0",
    "hedera-agent-kit": "^3.7.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@swc/jest": "^0.2.39",
    "@types/jest": "^30.0.0",
    "@typescript-eslint/eslint-plugin": "^8.48.1",
    "@typescript-eslint/parser": "^8.48.1",
    "eslint": "^9.39.1",
    "jest": "^30.2.0",
    "ts-node": "^10.9.2",
    "tsup": "^8.5.1",
    "tsx": "^4.20.6",
    "typescript": "5.6.3"
  },
  "resolutions": {
    "@hashgraphonline/standards-sdk": "^0.1.150",
    "@hashgraphonline/hashinal-wc": "^2.0.57",
    "@hashgraph/sdk": "2.79.0"
  },
  "packageManager": "pnpm@9.15.0+sha512.76e2379760a4328ec4415815bcd6628dee727af3779aaa4c914e3944156c4299921a89f976381ee107d41f12cfa4b66681ca9c718f0668fa0831ed4c6d8ba56c"
}
